# Copy to .env.local for local dev, and set the same values in your Vercel
# project (Settings -> Environment Variables). Leaving these unset runs the app
# in open "demo mode" with no login required.

# --- Client (safe to expose; bundled into the browser) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Email allowed to bootstrap the first admin account:
VITE_ADMIN_EMAIL=bernard@teamcerium.com

# --- Server only (NEVER expose; used by the /api serverless functions) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
ADMIN_EMAIL=bernard@teamcerium.com
